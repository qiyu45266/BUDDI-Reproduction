# but block everything else under datasets/. Re-extract with
# repro/shared/env/4_extract_datasets.sh after placing the tarballs in datasets/.
datasets/original/
datasets/*.tar
datasets/*.tar.gz
datasets/*.tgz
datasets/*.zip
datasets/*.7z
# Catch any extracted media we might've missed (images, videos, mocap clips)
datasets/**/*.png
datasets/**/*.jpg
datasets/**/*.jpeg
datasets/**/*.mp4
datasets/**/*.avi
datasets/**/*.mov
datasets/**/*.npz
